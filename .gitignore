# -*- mode: gitignore; encoding: utf-8 -*-

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
*.egg-info/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
virtualenv/

# =============================================================================
# Environment & secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.template
*.key
api_key*
secret*
credentials*
.pypirc

# =============================================================================
# IDE & editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
.history

# =============================================================================
# OS files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.lnk

# =============================================================================
# Generated site output
# =============================================================================
site/*
!site/.gitkeep
!site/index.html
!site/daily/index.html

# =============================================================================
# Data storage (keep dir, ignore contents)
# =============================================================================
data/*
!data/.gitkeep
!data/README.md

# =============================================================================
# Build artifacts & generated files
# =============================================================================
*.so
*.dylib
*.dll
*.class

# =============================================================================
# Testing & coverage
# =============================================================================
.coverage
coverage/
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.trx
.tox/
nosetests.xml

# =============================================================================
# Logs & dumps
# =============================================================================
*.log
*ses_*.md

# =============================================================================
# LLM / API artifacts
# =============================================================================
*.openai_*
*.gemini_*
*.claude_*
prompts/
swarmscratch/
agent_scratchpad/

# =============================================================================
# Dependency files (generated)
# =============================================================================
.python-version
uv.lock
Pipfile.lock
poetry.lock

# =============================================================================
# Internal tooling
# =============================================================================
.omo/
.opencode/
tmp/
temp/

# =============================================================================
# OS-specific junk
# =============================================================================
core
*.core
vgcore.*

# Devcontainer (keep template, ignore local configs)

# Environment overrides
.env.local
.env.production
