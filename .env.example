# =============================================================================
# OhMyInfo — 环境变量模板
# =============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# ⚠️  .env 文件包含敏感信息，切勿提交到版本控制。
#     项目 .gitignore 已排除 .env 文件。
# =============================================================================

# ---------------------------------------------------------------------------
# 必需：LLM API 密钥
# ---------------------------------------------------------------------------

# OpenAI API Key（用于文章评分）
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API Key（用于中文摘要和翻译）
# 获取地址: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# 可选：其他 Provider API 密钥
# ---------------------------------------------------------------------------

# Anthropic / Claude API Key
# 获取地址: https://console.anthropic.com/
# 留空则使用默认 Provider
ANTHROPIC_API_KEY=

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com/
# 留空则使用默认 Provider
DEEPSEEK_API_KEY=

# ---------------------------------------------------------------------------
# 可选：第三方服务令牌
# ---------------------------------------------------------------------------

# GitHub Token（提升 API 请求频率限制）
# 用于 GitHub Trending 数据采集，非必需但建议设置
# 创建地址: https://github.com/settings/tokens
GITHUB_TOKEN=
